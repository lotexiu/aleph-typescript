{
  "name": "aleph-typescript",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo dev",
    "format": "prettier --use-tabs --write \"**/*.{ts,tsx,md}\"",
    "new": "turbo gen workspace",
    "mismatch": "node scripts/syncpack-mismatch.mjs lint",
    "mismatch:fix": "node scripts/syncpack-mismatch.mjs fix",
    "upd-safe": "pnpm up -r && pnpm mismatch:fix && pnpm install && pnpm mismatch",
    "upd": "pnpm up -r",
    "outd": "pnpm outdated -r",
    "start": "pnpm git-sync && pnpm i",
    "get-changes": "node scripts/compare-repos.mjs",
    "git-init": "git submodule update --init --recursive",
    "git-sub-branch": "git submodule foreach 'branch=$(git symbolic-ref --short -q refs/remotes/origin/HEAD); git checkout ${branch#origin/} || git checkout main'",
    "git-sub-update": "git submodule update --remote --recursive",
    "git-sync": "pnpm git-init && pnpm git-sub-branch && pnpm git-sub-update && git pull",
    "clean": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' + && pnpm store prune"
  },
  "devDependencies": {
    "@grafana/levitate": "^0.17.2",
    "@microsoft/api-extractor": "^7.58.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-react": "^5.2.0",
    "chalk": "^5.6.2",
    "fs-extra": "^11.3.4",
    "ora": "^9.3.0",
    "prettier": "^3.8.2",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^4.5.4"
  },
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": ">=18"
  }
}
